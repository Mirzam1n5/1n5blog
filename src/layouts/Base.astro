---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mirzam', description = 'Embedded systems, low-level software, and occasional writing.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Mirzam' ? 'Mirzam' : `${title} — Mirzam`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <div id="starfield-wrap" style="position:absolute;top:0;left:0;width:100%;height:480px;pointer-events:none;z-index:0;overflow:hidden;">
      <canvas id="stars-canvas" style="display:block;width:100%;height:100%;"></canvas>
    </div>

    <nav class="nav">
      <a href="/" class="nav-logo">mirzam</a>
      <div class="nav-right">
        <ul class="nav-links">
          <li><a href="/" class={currentPath === '/' ? 'active' : ''}>home</a></li>
          <li><a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>blog</a></li>
          <li><a href="/projects" class={currentPath.startsWith('/projects') ? 'active' : ''}>projects</a></li>
          <li><a href="/gallery" class={currentPath.startsWith('/gallery') ? 'active' : ''}>gallery</a></li>
        </ul>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <span class="toggle-dot" id="toggle-dot"></span>
          <span id="toggle-label">light</span>
        </button>
      </div>
    </nav>

    <slot />

    <footer class="footer" style="margin-top: 48px;">
      <div class="footer-links">
        <a href="https://github.com/Mirzam1n5" target="_blank" rel="noopener">github</a>
        <a href="https://twitter.com/mirzam1n5" target="_blank" rel="noopener">twitter</a>
        <a href="mailto:mirzam1nn5@gmail.com">email</a>
      </div>
    </footer>

  </body>
</html>

<script>
  // ── Theme ──────────────────────────────────────────────
  const root = document.documentElement;

  // Apply saved theme immediately (before paint)
  const saved = localStorage.getItem('theme');
  if (saved === 'light') root.classList.add('light');

  const btn   = document.getElementById('theme-toggle');
  const label = document.getElementById('toggle-label');
  const dot   = document.getElementById('toggle-dot');

  function syncUI() {
    const light = root.classList.contains('light');
    label.textContent      = light ? 'dark' : 'light';
    dot.style.background   = light ? 'var(--text-primary)' : '';
  }

  syncUI();

  btn.addEventListener('click', () => {
    root.classList.toggle('light');
    localStorage.setItem('theme', root.classList.contains('light') ? 'light' : 'dark');
    syncUI();
    initStars();
  });

  // ── Starfield ──────────────────────────────────────────
  const canvas = document.getElementById('stars-canvas');
  const ctx    = canvas.getContext('2d');
  let stars = [], meteors = [], raf = null;

  function spawnMeteor(W, H, scattered) {
    meteors.push({
      x:     Math.random() * W * 1.4 - W * 0.2,
      y:     Math.random() * H * 0.35,
      len:   Math.random() * 100 + 60,
      speed: Math.random() * 2.5 + 1.5,
      alpha: Math.random() * 0.5 + 0.35,
      t:     scattered ? Math.random() * 0.8 : 0,
      life:  Math.random() * 0.8 + 0.6,
    });
  }

  function initStars() {
    if (raf !== null) { cancelAnimationFrame(raf); raf = null; }

    const isDark = !root.classList.contains('light');
    const wrap   = document.getElementById('starfield-wrap');
    const W      = wrap.offsetWidth  || window.innerWidth;
    const H      = wrap.offsetHeight || 480;

    canvas.width  = W;
    canvas.height = H;

    if (!isDark) {
      ctx.clearRect(0, 0, W, H);
      return;
    }

    stars = Array.from({ length: 180 }, () => ({
      x:  Math.random() * W,
      y:  Math.random() * H,
      r:  Math.random() * 1.2 + 0.15,
      a:  Math.random(),
      da: (Math.random() - 0.5) * 0.007,
    }));

    meteors = [];
    for (let i = 0; i < 4; i++) spawnMeteor(W, H, true);

    loop(W, H);
  }

  function loop(W, H) {
    if (root.classList.contains('light')) {
      ctx.clearRect(0, 0, W, H);
      raf = null;
      return;
    }

    ctx.clearRect(0, 0, W, H);

    // Stars
    for (const s of stars) {
      s.a += s.da;
      if (s.a <= 0 || s.a >= 1) s.da *= -1;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180,192,215,${s.a * 0.75})`;
      ctx.fill();
    }

    // Meteors
    const dx = Math.cos(Math.PI / 5.5);
    const dy = Math.sin(Math.PI / 5.5);

    for (let i = meteors.length - 1; i >= 0; i--) {
      const m = meteors[i];
      m.t += 0.016 / m.life;

      const progress = m.t;
      const ex = m.x + m.speed * progress * W * 0.45 * dx;
      const ey = m.y + m.speed * progress * W * 0.45 * dy;
      const sx = ex - m.len * dx;
      const sy = ey - m.len * dy;

      const fade = progress < 0.15
        ? progress / 0.15
        : progress > 0.65
          ? (1 - progress) / 0.35
          : 1;

      const g = ctx.createLinearGradient(sx, sy, ex, ey);
      g.addColorStop(0, 'rgba(200,212,235,0)');
      g.addColorStop(1, `rgba(200,212,235,${Math.max(0, fade * m.alpha)})`);

      ctx.beginPath();
      ctx.moveTo(sx, sy);
      ctx.lineTo(ex, ey);
      ctx.strokeStyle = g;
      ctx.lineWidth   = 1.3;
      ctx.stroke();

      if (m.t >= 1) {
        meteors.splice(i, 1);
        spawnMeteor(W, H, false);
      }
    }

    raf = requestAnimationFrame(() => loop(W, H));
  }

  window.addEventListener('resize', initStars);
  // Wait for layout to settle before reading offsetWidth
  requestAnimationFrame(() => initStars());
</script>
