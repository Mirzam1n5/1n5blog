---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

let projects = [];
try {
  const res = await fetch('https://api.github.com/users/Mirzam1n5/repos?sort=updated&per_page=6');
  if (res.ok) {
    const data = await res.json();
    projects = data.filter((r) => !r.fork).slice(0, 4);
  }
} catch { projects = []; }

function langClass(lang) {
  if (!lang) return 'lang-other';
  const map = { 'C':'lang-c','C++':'lang-cpp','Rust':'lang-rust','Python':'lang-python','VHDL':'lang-vhdl' };
  return map[lang] ?? 'lang-other';
}

function formatDate(date) {
  return new Date(date).toISOString().slice(0, 7);
}
---

<Base>
  <section class="hero">
    <div class="hero-left">
      <p class="hero-eyebrow">mira · 19 · kz</p>
      <h1 class="hero-name">Mirzam.</h1>
      <p class="hero-handle">@mirzam1n5</p>
      <p class="hero-bio">
        Embedded systems and low-level software engineering student.
        I work close to the metal —
        <em>bare-metal C, Rust, RTOS</em> —
        and keep learning more.
        Finishing up a software dev program at college.
        Occasionally write about things I figure out.
      </p>
      <div class="hero-stack">
        <span class="tag tag-hi">C</span>
        <span class="tag tag-hi">C++</span>
        <span class="tag tag-hi">Rust</span>
        <span class="tag">Assembly</span>
        <span class="tag">Bash</span>
        <span class="tag">FPGA</span>
        <span class="tag">Raspberry Pi</span>
        <span class="tag">RTOS</span>
      </div>
      <div class="hero-links">
        <a href="https://github.com/Mirzam1n5" target="_blank" rel="noopener">github</a>
        <a href="https://twitter.com/mirzam1n5" target="_blank" rel="noopener">twitter / x</a>
        <a href="mailto:mirzam1nn5@gmail.com">email</a>
      </div>
    </div>

    <div class="avatar-wrap">
      <div class="avatar-frame">
        <img src="/avatar.jpg" alt="Mira"
          onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--text-dim);font-size:11px;letter-spacing:.06em\'>photo</div>'" />
      </div>
    </div>
  </section>

  <hr class="section-rule" />

  <section class="section">
    <div class="section-header">
      <span class="section-label">writing</span>
      <a href="/blog" class="see-more">all posts →</a>
    </div>
    {posts.length === 0 ? (
      <p style="color: var(--text-dim); font-size: 12px; padding: 16px 0;">no posts yet.</p>
    ) : (
      <div class="posts-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-card-meta">
              <span class="post-date">{formatDate(post.data.date)}</span>
              <span class="post-tag">{post.data.tags?.[0] ?? ''}</span>
            </div>
            <div class="post-card-title">{post.data.title}</div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="section" style="padding-top: 40px;">
    <div class="section-header">
      <span class="section-label">projects</span>
      <a href="/projects" class="see-more">all projects →</a>
    </div>
    {projects.length === 0 ? (
      <div class="projects-grid">
        <a href="https://github.com/Mirzam1n5" class="project-card" target="_blank" rel="noopener">
          <p class="project-name">rpi-sensor-hub</p>
          <p class="project-desc">Raspberry Pi multi-sensor aggregator with I²C and SPI support. Work in progress.</p>
          <div class="project-meta"><span class="project-lang lang-c">C</span><span>in progress</span></div>
        </a>
        <a href="https://github.com/Mirzam1n5" class="project-card" target="_blank" rel="noopener">
          <p class="project-name">your-project</p>
          <p class="project-desc">Push repos to GitHub — they'll appear here automatically.</p>
          <div class="project-meta"><span class="project-lang lang-other">—</span></div>
        </a>
      </div>
    ) : (
      <div class="projects-grid">
        {projects.map((repo) => (
          <a href={repo.html_url} class="project-card" target="_blank" rel="noopener">
            <p class="project-name">{repo.name}</p>
            <p class="project-desc">{repo.description ?? 'no description.'}</p>
            <div class="project-meta">
              {repo.language && <span class={`project-lang ${langClass(repo.language)}`}>{repo.language}</span>}
              {repo.stargazers_count > 0 && <span>{repo.stargazers_count} stars</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
